# ── Secrets / local config ──
.env

# ── Python ──
__pycache__/
*.pyc
*.pyo

# ── Runtime data / artifacts ──
data/collected/
data/train_dataset/
data/zones.json
data/*.yaml
data/*_coco.json
datasets/
logs/
runs/
models/*.pt
*.onnx
*.engine
*.log

# Safety net: never commit any image/weights under data/ (training frames)
data/**/*.jpg
data/**/*.jpeg
data/**/*.png

# ── Debug ──
debug_*.jpg
/yolo*.pt
/*.pt

# Ignore all local model runs/weights (regenerated by training)
models/
# ...but assets/models holds small, license-cleared vendored artifacts that MUST
# ship (the 313KB MIT fall-detection Transformer). `models/` above matches any
# directory of that name, so re-include this one explicitly.
!assets/models/
!assets/models/**
