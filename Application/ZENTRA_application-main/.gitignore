# Training artifacts + test/demo media (large, regenerable — not source)
runs/
demos/
*.mp4
backend/archive/

# Model weights never belong in git
*.pt
*.onnx
*.tflite
!backend/assets/models/*.tflite

# Archived model weights (1.1 GB, moved out of the live tree — see model_archive/MANIFEST.md)
model_archive/**
!model_archive/MANIFEST.md
backend/logs/
backend/models/person_v1/
