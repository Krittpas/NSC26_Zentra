# ZENTRA — Environment Configuration (template)
# Copy to .env and fill in your real values:  cp .env.example .env
# All values are optional — the app runs with sensible defaults from config.py.
# ================================================================

# ── AI models (run IN-PROCESS via ultralytics — no Docker inference server) ──
# The deployed engine loads local .pt weights directly; nothing listens on :9001.
# Put weights in backend/models/ (see README → "Models"):
#   ppe_finetuned.pt  (PPE items)   ·  yolo11s.pt (person)  ·  yolo11n-pose.pt (fall)
# The person + pose models auto-download from ultralytics if missing; the PPE
# fine-tune is yours and cannot auto-download.
USE_LOCAL_MODEL=true
# PPE_INFER_DEVICE: leave blank to auto-pick (MPS → CUDA → CPU); set "cuda"/"cpu"
# to force a device (e.g. on a factory GPU host).
PPE_INFER_DEVICE=

# ── API auth (RECOMMENDED before exposing beyond localhost) ──
# The API has NO authentication by default and is bound to 127.0.0.1 for that
# reason. Set a long random secret here to require "Authorization: Bearer <token>"
# on every /api and /ws call, so the app can sit behind a reverse proxy / on a LAN
# without exposing worker evidence photos, the event log, or the training job
# spawner. Leave blank = no auth (localhost only). The desktop app passes it to the
# UI automatically.
ZENTRA_API_TOKEN=

# ── Camera ───────────────────────────────────────────────────
# source: webcam | rtsp | file   (the desktop app overrides this at runtime)
CAMERA_SOURCE=webcam
WEBCAM_INDEX=0
USE_DSHOW=true
# Your camera's own RTSP URL, e.g. rtsp://<user>:<pass>@<host>:554/stream1
# (no credentials are baked into the code — set your real one here).
RTSP_URL=
VIDEO_FILE_PATH=

# ── Inference cadence / stream ───────────────────────────────
INFER_EVERY_N_FRAMES=2
STREAM_FPS=15

# ── LINE OA Alerts (leave blank to disable LINE delivery) ────
# Events still appear in the app and History even without these.
# The channel access token is a bearer credential — keep .env out of git.
LINE_OA_CHANNEL_ACCESS_TOKEN=
LINE_OA_GROUP_SUPERVISOR=
LINE_OA_GROUP_SAFETY=
LINE_OA_GROUP_EMERGENCY=

# PDPA: OFF by default — LINE alerts are text-only and no person image leaves the
# device. Turning this on uploads evidence photos to an external public host.
LINE_UPLOAD_IMAGES=false

# ── Daily report time (HH:MM, 24h) ──────────────────────────
DAILY_REPORT_TIME=20:00

# ── Training (tuned for a 4 GB GPU like RTX 3050) ───────────
# yolov8n = fastest/lightest, yolov8s = better accuracy if VRAM allows.
# yolov8m needs ~8 GB+; drop batch if you hit CUDA out-of-memory.
YOLO_BASE_MODEL=yolov8s.pt
TRAIN_DEVICE=0
TRAIN_BATCH_SIZE=4
TRAIN_EPOCHS=100
TRAIN_WORKERS=4
