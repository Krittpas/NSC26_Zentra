# ── Secrets / local config ──
.env

# ── Python ──
__pycache__/
*.pyc
*.pyo

# ── Runtime data / artifacts ──
data/collected/
data/train_dataset/
data/zones.json
data/*.yaml
data/*_coco.json
datasets/
logs/
runs/
models/*.pt
*.onnx
*.engine
*.log

# Fall evaluation clips + whatever the harness writes about them. These are VIDEOS
# OF PEOPLE — public-dataset subjects and, once you film the sitting-on-the-floor
# negative, your own colleagues. They must never reach a remote.
# (docs/FALL_STAGE0.md always claimed this folder was ignored. Until now it was not:
#  the image rules below cover .jpg/.png, and a clip is an .mp4.)
data/fall_clips/

# Safety net: never commit any image/video/weights under data/ (training frames,
# evidence snapshots, evaluation clips)
data/**/*.jpg
data/**/*.jpeg
data/**/*.png
data/**/*.mp4
data/**/*.avi
data/**/*.mov
data/**/*.mkv

# ── Debug ──
debug_*.jpg
/yolo*.pt
/*.pt

# Ignore all local model runs/weights (regenerated by training)
models/
# ...but assets/models holds small, license-cleared vendored artifacts that MUST
# ship (the 313KB MIT fall-detection Transformer). `models/` above matches any
# directory of that name, so re-include this one explicitly.
!assets/models/
!assets/models/**
